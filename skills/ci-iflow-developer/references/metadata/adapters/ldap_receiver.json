      "key": "ldapOperation",
      "values": [
        {
          "key": "ldapOperationInsert",
          "label": "Insert"
        },
        {
          "key": "ldapOperationDelete",
          "label": "Delete"
        },
        {
          "key": "ldapOperationModify",
          "label": "Modify"
        },
        {
          "key": "ldapOperationSearch",
          "label": "Search"
        }
      ]
    },
    {
      "externalizable": true,
      "label": "Base DN",
      "key": "ldapBaseDN",
