    {
      "externalizable": true,
      "mandatory": true,
      "defaultValue": "10",
      "label": "Size Limit",
      "key": "countLimit",
      "when": "ldapOperation in ['ldapOperationSearch']"
    },
    {
      "externalizable": true,
      "mandatory": true,
      "defaultValue": "1",
      "label": "Timeout (in min)",
      "key": "timeLimit",
      "when": "ldapOperation in ['ldapOperationSearch']"
    }
  ]
