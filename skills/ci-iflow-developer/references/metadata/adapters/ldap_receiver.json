      "key": "ldapProxyType",
      "values": [
        {
          "key": "ldapProxyTypeOnPremise",
          "label": "On Premise"
        },
        {
          "key": "ldapProxyTypeInternet",
          "label": "Internet"
        }
      ]
    },
    {
      "externalizable": true,
      "label": "Location ID",
      "key": "ldapLocationID",
      "when": "ldapProxyType in ['ldapProxyTypeOnPremise']"
    },
    {
      "externalizable": true,
      "defaultValue": "ldapAuthenticationSimple",
      "label": "Authentication",
      "key": "ldapAuthentication",
      "values": [
        {
          "key": "ldapAuthenticationSimple",
          "label": "Simple"
        }
      ]
    },
    {
      "externalizable": true,
      "mandatory": true,
      "label": "Credential Name",
      "key": "ldapCredentialName"
    },
    {
