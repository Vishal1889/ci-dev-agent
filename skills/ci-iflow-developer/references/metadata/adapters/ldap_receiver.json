      "key": "ldapModificationType",
      "values": [
        {
          "key": "add",
          "label": "Add"
        },
        {
          "key": "replace",
          "label": "Replace"
        },
        {
          "key": "remove",
          "label": "Remove"
        }
      ]
    },
    {
      "externalizable": true,
      "dataType": "xsd:boolean",
      "label": "Consider additional attributes for modification",
      "key": "ldapPayloadAttributeProcessing"
    },
    {
      "externalizable": true,
      "mandatory": true,
      "label": "Search Filter",
      "key": "ldapSearchFilter",
