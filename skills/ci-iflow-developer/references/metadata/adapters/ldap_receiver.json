      "key": "ldapOutputType",
      "when": "ldapOperation in ['ldapOperationSearch']",
      "values": [
        {
          "key": "ldapOutputTypeXML",
          "label": "XML"
        },
        {
          "key": "ldapOutputTypeLDAPAttributes",
          "label": "Java (JNDI) Attributes"
        }
      ]
    },
    {
