{
  "name": "LDAP",
  "direction": "Receiver",
  "adapterVariantURI": "ctype::AdapterVariant/cname::sap:LDAP/tp::TCP/mp::LDAP/direction::Receiver/version::1.4.1",
  "componentVersion": "1.4.1",
  "messageProtocol": "LDAP",
  "transportProtocol": "TCP",
  "ComponentNS": "sap",
  "ComponentSWCVName": "external",
