{
  "name": "FTP",
  "direction": "Receiver",
  "adapterVariantURI": "ctype::AdapterVariant/cname::sap:FTP/tp::FTP/mp::File/direction::Receiver/version::1.2.0",
  "componentVersion": "1.2.0",
  "messageProtocol": "File",
  "transportProtocol": "FTP",
  "ComponentNS": "sap",
  "ComponentSWCVName": "external",
  "ComponentSWCVId": "1.4.1",
  "properties": [
    {
      "externalizable": true,
      "label": "Directory",
      "key": "path"
    },
    {
      "externalizable": true,
      "label": "File Name",
      "key": "fileName"
    },
    {
      "externalizable": true,
      "dataType": "xsd:boolean",
      "label": "Append Timestamp",
      "key": "fileAppendTimeStamp"
    },
    {
      "externalizable": true,
      "mandatory": true,
      "label": "Address",
      "key": "host"
    },
    {
      "externalizable": true,
      "defaultValue": "none",
      "label": "Proxy Type",
      "key": "proxyType",
      "values": [
        {
          "key": "none",
          "label": "Internet"
        },
        {
          "key": "sapcc",
          "label": "On-Premise"
        },
        {
          "key": "dynamic",
          "label": "Dynamic"
        },
        {
          "key": "none",
          "label": "Internet"
        },
        {
          "key": "manual",
          "label": "Manual"
        }
      ]
    },
    {
      "externalizable": true,
      "mandatory": true,
      "label": "Proxy Host",
      "key": "proxyHost",
      "when": "proxyType in ['manual']"
    },
    {
      "externalizable": true,
      "mandatory": true,
      "defaultValue": "8080",
      "dataType": "xsd:integer",
      "label": "Proxy Port",
      "key": "proxyPort",
      "when": "proxyType in ['manual']"
    },
    {
      "externalizable": true,
      "label": "Proxy Credential Name",
      "key": "proxyAlias",
      "when": "proxyType in ['manual']"
    },
    {
      "externalizable": true,
      "label": "Location ID",
      "key": "location_id",
      "when": "proxyType in ['sapcc'] OR proxyType in ['dynamic']"
    },
    {
      "externalizable": true,
      "defaultValue": "ftpes",
      "label": "Encryption",
      "key": "encryption",
      "values": [
        {
          "key": "ftp",
          "label": "Plain FTP - no encryption"
        },
        {
          "key": "ftps",
          "label": "Implicit FTPS"
        },
        {
          "key": "ftpes",
          "label": "Explicit FTPS"
        },
        {
          "key": "dynamic",
          "label": "Dynamic"
        }
      ]
    },
    {
      "externalizable": true,
      "mandatory": true,
      "label": "Credential Name",
      "key": "credential_name"
    },
    {
      "externalizable": true,
      "defaultValue": "10000",
      "dataType": "xsd:integer",
      "label": "Timeout (in ms)",
      "key": "connectTimeout"
    },
    {
      "externalizable": true,
      "defaultValue": "3",
      "dataType": "xsd:integer",
      "label": "Maximum Reconnect Attempts",
      "key": "maximumReconnectAttempts"
    },
    {
      "externalizable": true,
      "defaultValue": "1000",
      "dataType": "xsd:integer",
      "label": "Reconnect Delay (in ms)",
      "key": "reconnectDelay"
    },
    {
      "externalizable": true,
      "dataType": "xsd:boolean",
      "label": "Automatically Disconnect",
      "key": "disconnect"
    },
    {
      "externalizable": true,
      "defaultValue": "0",
      "dataType": "xsd:boolean",
      "label": "Change Directories Stepwise",
      "key": "stepwise"
    },
    {
      "externalizable": true,
      "defaultValue": "1",
      "dataType": "xsd:boolean",
      "label": "Create Directories",
      "key": "autoCreate"
    },
    {
      "externalizable": true,
      "dataType": "xsd:boolean",
      "label": "Flatten File Names",
      "key": "flatten"
    },
    {
      "externalizable": true,
      "mandatory": true,
      "defaultValue": "1",
      "dataType": "xsd:boolean",
      "label": "Prevent Directory Traversal",
      "key": "sftpSecEnabled"
    },
    {
      "externalizable": true,
      "defaultValue": "Override",
      "label": "Handling for Existing Files",
      "key": "fileExist",
      "values": [
        {
          "key": "Override",
          "label": "Override"
        },
        {
          "key": "Append",
          "label": "Append"
        },
        {
          "key": "Fail",
          "label": "Fail"
        },
        {
          "key": "Ignore",
          "label": "Ignore"
        }
      ]
    },
    {
      "externalizable": true,
      "defaultValue": "0",
      "dataType": "xsd:boolean",
      "label": "Use Temporary File",
      "key": "useTempFile",
      "when": "NOT (fileExist in ['Append'])"
    },
    {
      "externalizable": true,
      "mandatory": true,
      "defaultValue": "${file:name}.tmp",
      "label": "Temporary File Name",
      "key": "tempFileName"
    }
  ]
}
