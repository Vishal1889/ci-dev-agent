{
  "name": "OData",
  "direction": "Receiver",
  "adapterVariantURI": "ctype::AdapterVariant/cname::sap:HCIOData/tp::HTTP/mp::OData V2/direction::Receiver/version::1.27.0",
  "componentVersion": "1.27.0",
  "messageProtocol": "OData V2",
  "transportProtocol": "HTTP",
  "ComponentNS": "sap",
  "ComponentSWCVName": "external",
  "ComponentSWCVId": "1.27.0",
  "properties": [
    {
      "externalizable": true,
      "mandatory": true,
      "label": "Address",
      "key": "address"
    },
    {
      "label": "Type",
      "key": "apiArtifactType"
    },
    {
      "externalizable": true,
      "key": "providerRelativeUrl",
      "when": "apiArtifactType in ['API Provider']"
    },
    {
      "label": "Destination",
      "key": "providerName",
      "when": "apiArtifactType in ['API Provider']"
    },
    {
      "externalizable": true,
      "mandatory": true,
      "defaultValue": "default",
      "label": "Proxy Type",
      "key": "proxyType",
      "when": "NOT (apiArtifactType in ['API Provider'])",
      "values": [
        {
          "key": "default",
          "label": "Internet"
        },
        {
          "key": "sapcc",
          "label": "On-Premise"
        },
        {
          "key": "manual",
          "label": "Manual"
        }
      ]
    },
    {
      "label": "Proxy Type",
      "key": "internetProxyType",
      "when": "apiArtifactType in ['API Provider']"
    },
    {
      "externalizable": true,
      "mandatory": true,
      "label": "Proxy Host",
      "key": "proxyHost",
      "when": "proxyType in ['manual']"
    },
    {
      "externalizable": true,
      "mandatory": true,
      "dataType": "xsd:integer",
      "label": "Proxy Port",
      "key": "proxyPort",
      "when": "proxyType in ['manual']"
    },
    {
      "externalizable": true,
      "label": "Location ID",
      "key": "scc_location_id",
      "when": "proxyType in ['sapcc']"
    },
    {
      "externalizable": true,
      "mandatory": true,
      "defaultValue": "None",
      "label": "Authentication",
      "key": "authenticationMethod",
      "when": "NOT (apiArtifactType in ['API Provider'])",
      "values": [
        {
          "key": "None",
          "label": "None"
        },
        {
          "key": "Basic",
          "label": "Basic"
        },
        {
          "key": "OAuth2SAMLBearer",
          "label": "OAuth2 SAML Bearer Assertion"
        },
        {
          "key": "SAP_PP",
          "label": "Principal Propagation"
        },
        {
          "key": "Client Certificate",
          "label": "Client Certificate"
        },
        {
          "key": "OAuth2ClientCredentials",
          "label": "OAuth2 Client Credentials"
        }
      ]
    },
    {
      "externalizable": true,
      "mandatory": true,
      "label": "Credential Name",
      "key": "alias",
      "when": "authenticationMethod in ['Basic'] OR authenticationMethod in ['OAuth2ClientCredentials'] OR authenticationMethod in ['OAuth2SAMLBearer']"
    },
    {
      "externalizable": true,
      "label": "Private Key Alias",
      "key": "odataCertAuthPrivateKeyAlias",
      "when": "authenticationMethod in ['Client Certificate']"
    },
    {
      "externalizable": true,
      "mandatory": true,
      "defaultValue": "true",
      "dataType": "xsd:boolean",
      "label": "CSRF Protected",
      "key": "isCSRFEnabled",
      "when": "apiArtifactType in ['']"
    },
    {
      "externalizable": true,
      "defaultValue": "true",
      "dataType": "xsd:boolean",
      "label": "Reuse Connection",
      "key": "enableTLSSessionReuse",
      "when": "apiArtifactType in ['']"
    },
    {
      "label": "Authentication",
      "key": "providerAuth",
      "when": "apiArtifactType in ['API Provider']"
    },
    {
      "label": "URL",
      "key": "providerUrl",
      "when": "apiArtifactType in ['API Provider']"
    },
    {
      "mandatory": true,
      "defaultValue": "Query(GET)",
      "label": "Operation Details",
      "key": "operation",
      "values": [
        {
          "key": "Create(POST)",
          "label": "Create (POST)"
        },
        {
          "key": "Merge(MERGE)",
          "label": "Merge (MERGE)"
        },
        {
          "key": "Update(PUT)",
          "label": "Update (PUT)"
        },
        {
          "key": "Query(GET)",
          "label": "Query (GET)"
        },
        {
          "key": "Read(GET)",
          "label": "Read (GET)"
        },
        {
          "key": "Delete(DELETE)",
          "label": "Delete (DELETE)"
        },
        {
          "key": "Patch(PATCH)",
          "label": "Patch (PATCH)"
        },
        {
          "key": "FunctionImport",
          "label": "Function Import"
        },
        {
          "key": "DynamicOperation",
          "label": "Dynamic"
        },
        {
          "key": "Dynamic",
          "label": "Dynamic"
        }
      ]
    },
    {
      "externalizable": true,
      "mandatory": true,
      "label": "Expression",
      "key": "odataOperationExpression",
      "when": "operation in ['DynamicOperation']"
    },
    {
      "externalizable": true,
      "mandatory": true,
      "label": "Resource Path",
      "key": "resourcePath",
      "when": "NOT (operation in ['Dynamic'])"
    },
    {
      "externalizable": true,
      "label": "Fields",
      "key": "fields",
      "when": "operation in ['Create(POST)'] OR operation in ['Merge(MERGE)'] OR operation in ['Update(PUT)'] OR operation in ['Patch(PATCH)']"
    },
    {
      "externalizable": true,
      "label": "Query Options",
      "key": "queryOptions",
      "when": "operation in ['Query(GET)'] OR operation in ['Read(GET)'] OR operation in ['FunctionImport'] OR operation in ['DynamicOperation']"
    },
    {
      "externalizable": true,
      "dataType": "xsd:boolean",
      "label": "Enable Batch Processing",
      "key": "enableBatchProcessing",
      "when": "NOT (None in [])"
    },
    {
      "externalizable": true,
      "label": "Custom Query Options",
      "key": "customQueryOptions",
      "when": "NOT (operation in ['Dynamic'])"
    },
    {
      "externalizable": true,
      "defaultValue": "application/atom+xml",
      "label": "Content Type",
      "key": "contentType",
      "when": "NOT (operation in ['Dynamic'])",
      "values": [
        {
          "key": "application/atom+xml",
          "label": "Atom"
        },
        {
          "key": "application/json",
          "label": "JSON"
        }
      ]
    },
    {
      "externalizable": true,
      "defaultValue": "none",
      "label": "Content Type Encoding",
      "key": "characterEncoding",
      "when": "operation in ['Create(POST)'] OR operation in ['Update(PUT)'] OR operation in ['Merge(MERGE)'] OR operation in ['FunctionImport'] OR operation in ['Patch(PATCH)'] OR operation in ['DynamicOperation']",
      "values": [
        {
          "key": "none",
          "label": "None"
        },
        {
          "key": "utf8",
          "label": "UTF-8"
        }
      ]
    },
    {
      "externalizable": true,
      "dataType": "xsd:integer",
      "label": "Page Size",
      "key": "odatapagesize",
      "when": "operation in ['Query(GET)'] OR operation in ['Read(GET)']"
    },
    {
      "dataType": "xsd:boolean",
      "label": "Process in Pages",
      "key": "pagination",
      "when": "operation in ['Query(GET)']"
    },
    {
      "externalizable": true,
      "defaultValue": "true",
      "dataType": "xsd:boolean",
      "label": "Attach Error Details on Failure",
      "key": "enableMPLAttachments"
    },
    {
      "externalizable": true,
      "mandatory": true,
      "defaultValue": "1",
      "dataType": "xsd:integer",
      "label": "Timeout (in min)",
      "key": "receiveTimeOut"
    },
    {
      "externalizable": true,
      "key": "edmxFilePath",
      "when": "edmxFilePath in ['false']"
    },
    {
      "externalizable": true,
      "label": "Request Headers",
      "key": "whitelistRequestHeaders"
    },
    {
      "externalizable": true,
      "label": "Response Headers",
      "key": "whitelistResponseHeaders"
    },
    {
      "externalizable": true,
      "label": "Request Headers",
      "key": "metadataAllowedHeaders"
    },
    {
      "externalizable": true,
      "label": "Custom Query Parameters",
      "key": "metadataAllowedURIParams"
    }
  ]
}
