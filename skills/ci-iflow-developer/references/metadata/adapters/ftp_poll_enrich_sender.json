{
  "name": "PollingFTP",
  "direction": "Sender",
  "adapterVariantURI": "ctype::AdapterVariant/cname::sap:PollingFTP/tp::FTP/mp::File/direction::Sender/version::1.0.0",
  "componentVersion": "1.0.0",
  "messageProtocol": "File",
  "transportProtocol": "FTP",
  "ComponentNS": "sap",
  "ComponentSWCVName": "external",
  "ComponentSWCVId": "1.0.0",
  "properties": [
    {
      "externalizable": true,
      "label": "Directory",
      "key": "path"
    },
    {
      "externalizable": true,
      "defaultValue": "*",
      "label": "File Name",
      "key": "fileName"
    },
    {
      "externalizable": true,
      "mandatory": true,
      "label": "Address",
      "key": "host"
    },
    {
      "externalizable": true,
      "defaultValue": "none",
      "label": "Proxy Type",
      "key": "proxyType",
      "values": [
        {
          "key": "none",
          "label": "Internet"
        },
        {
          "key": "sapcc",
          "label": "On-Premise"
        },
        {
          "key": "dynamic",
          "label": "Dynamic"
        },
        {
          "key": "none",
          "label": "Internet"
        },
        {
          "key": "manual",
          "label": "Manual"
        },
        {
          "key": "dynamic",
          "label": "Dynamic"
        }
      ]
    },
    {
      "externalizable": true,
      "mandatory": true,
      "label": "Proxy Host",
      "key": "proxyHost",
      "when": "proxyType in ['manual'] OR None in []"
    },
    {
      "externalizable": true,
      "mandatory": true,
      "defaultValue": "8080",
      "dataType": "xsd:integer",
      "label": "Proxy Port",
      "key": "proxyPort",
      "when": "proxyType in ['manual'] OR None in []"
    },
    {
      "externalizable": true,
      "label": "Proxy Credential Name",
      "key": "proxyAlias",
      "when": "proxyType in ['manual'] OR None in []"
    },
    {
      "externalizable": true,
      "label": "Location ID",
      "key": "location_id",
      "when": "proxyType in ['sapcc'] OR None in []"
    },
    {
      "externalizable": true,
      "defaultValue": "ftpes",
      "label": "Encryption",
      "key": "encryption",
      "values": [
        {
          "key": "ftp",
          "label": "Plain FTP - no encryption"
        },
        {
          "key": "ftps",
          "label": "Implicit FTPS"
        },
        {
          "key": "ftpes",
          "label": "Explicit FTPS"
        },
        {
          "key": "dynamic",
          "label": "Dynamic"
        }
      ]
    },
    {
      "externalizable": true,
      "mandatory": true,
      "label": "Credential Name",
      "key": "credential_name"
    },
    {
      "externalizable": true,
      "defaultValue": "10000",
      "dataType": "xsd:integer",
      "label": "Timeout (in ms)",
      "key": "connectTimeout"
    },
    {
      "externalizable": true,
      "defaultValue": "3",
      "dataType": "xsd:integer",
      "label": "Maximum Reconnect Attempts",
      "key": "maximumReconnectAttempts"
    },
    {
      "externalizable": true,
      "defaultValue": "1000",
      "dataType": "xsd:integer",
      "label": "Reconnect Delay (in ms)",
      "key": "reconnectDelay"
    },
    {
      "externalizable": true,
      "dataType": "xsd:boolean",
      "label": "Automatically Disconnect",
      "key": "disconnect"
    },
    {
      "externalizable": true,
      "defaultValue": "none",
      "label": "Read Lock Strategy",
      "key": "readLock",
      "values": [
        {
          "key": "none",
          "label": "None"
        },
        {
          "key": "rename",
          "label": "Rename"
        },
        {
          "key": "change",
          "label": "Content Change"
        },
        {
          "key": "doneFile",
          "label": "Done File Expected"
        }
      ]
    },
    {
      "externalizable": true,
      "mandatory": true,
      "defaultValue": "${file:name}.done",
      "label": "Done File Name",
      "key": "doneFileName",
      "when": "readLock in ['doneFile']"
    },
    {
      "externalizable": true,
      "defaultValue": "0",
      "dataType": "xsd:boolean",
      "label": "Change Directories Stepwise",
      "key": "stepwise"
    },
    {
      "externalizable": true,
      "dataType": "xsd:boolean",
      "label": "Include Subdirectories",
      "key": "recursive"
    },
    {
      "externalizable": true,
      "defaultValue": "delete",
      "label": "Post-Processing",
      "key": "noop",
      "values": [
        {
          "key": "delete",
          "label": "Delete File"
        },
        {
          "key": "mark",
          "label": "Keep File and Mark as Processed in Idempotent Repository"
        },
        {
          "key": "keepFileAndProcessAgain",
          "label": "Keep File and Process Again"
        },
        {
          "key": "move",
          "label": "Move File"
        }
      ]
    },
    {
      "externalizable": true,
      "mandatory": true,
      "defaultValue": ".archive",
      "label": "Archive Directory",
      "key": "file.move",
      "when": "noop in ['move']"
    }
  ]
}
