      "values": [
        {
          "key": "1",
          "label": "1"
        },
        {
          "key": "2",
          "label": "2"
        },
        {
          "key": "3",
          "label": "3"
        }
      ]
    },
    {
      "externalizable": true,
      "label": "Request Headers",
      "key": "allowedRequestHeaders"
    },
    {
      "externalizable": true,
      "defaultValue": "*",
      "label": "Response Headers",
      "key": "allowedResponseHeaders"
    }
