        {
          "key": "DELETE",
          "label": "DELETE"
        },
        {
          "key": "GET",
          "label": "GET"
        },
        {
          "key": "HEAD",
          "label": "HEAD"
        },
        {
          "key": "POST",
          "label": "POST"
        },
        {
          "key": "PUT",
          "label": "PUT"
        },
        {
          "key": "TRACE",
          "label": "TRACE"
        },
        {
          "key": "PATCH",
