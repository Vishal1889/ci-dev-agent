      "key": "PollDelay"
    },
    {
      "externalizable": true,
      "mandatory": true,
      "defaultValue": "1",
      "dataType": "xsd:integer",
      "label": "Retry Interval (in min)",
      "key": "RetryInterval"
    },
    {
      "externalizable": true,
      "mandatory": true,
      "defaultValue": "1",
      "dataType": "xsd:boolean",
      "label": "Exponential Backoff",
      "key": "ExponentialBackoff"
    },
    {
      "externalizable": true,
      "mandatory": true,
      "defaultValue": "60",
      "dataType": "xsd:integer",
      "label": "Maximum Retry Interval (in min)",
      "key": "MaxRetryInterval",
      "when": "ExponentialBackoff in ['1']"
    },
    {
      "externalizable": true,
      "mandatory": true,
      "defaultValue": "10",
      "dataType": "xsd:integer",
      "label": "Lock Timeout (in min)",
      "key": "file_lock_timeout"
    }
  ]
