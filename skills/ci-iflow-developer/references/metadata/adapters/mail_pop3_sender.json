  "properties": [
    {
      "externalizable": true,
      "mandatory": true,
      "label": "Address",
      "key": "server"
    },
    {
      "externalizable": true,
      "defaultValue": "none",
      "label": "Proxy Type",
      "key": "proxyType",
      "values": [
        {
          "key": "none",
          "label": "Internet"
        },
        {
          "key": "sapcc",
          "label": "On-Premise"
        },
        {
          "key": "none",
          "label": "Internet"
        },
        {
          "key": "manual",
          "label": "Manual"
        }
      ]
    },
    {
      "externalizable": true,
      "defaultValue": "socks5",
      "label": "Proxy Protocol",
      "key": "proxyProtocol",
