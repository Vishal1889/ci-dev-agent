      "values": [
        {
          "key": "http",
          "label": "HTTP"
        },
        {
          "key": "socks5",
          "label": "SOCKS Version 5"
        }
      ]
    },
    {
      "externalizable": true,
      "mandatory": true,
      "label": "Proxy Host",
      "key": "proxyHost",
