          "label": "POST"
        },
        {
          "key": "PUT",
          "label": "PUT"
        },
        {
          "key": "DELETE",
          "label": "DELETE"
        },
        {
          "key": "HEAD",
          "label": "HEAD"
        },
        {
          "key": "OPTIONS",
          "label": "OPTIONS"
        }
      ]
