          "label": "Dot(.)"
        },
        {
          "key": "|",
          "label": "Pipe(|)"
        },
        {
          "key": ";",
          "label": "Semicolon(;)"
        },
        {
          "key": "space",
          "label": "Space"
        }
      ]
    },
    {
      "externalizable": true,
      "label": "JSON Output Encoding",
      "key": "jsonOutputEncoding",
      "values": [
        {
          "key": "UTF-8",
          "label": "UTF-8"
        },
        {
          "key": "UTF-16BE",
          "label": "UTF-16BE"
        },
        {
          "key": "UTF-16LE",
          "label": "UTF-16LE"
        },
        {
          "key": "UTF-32BE",
          "label": "UTF-32BE"
        },
        {
          "key": "UTF-32LE",
          "label": "UTF-32LE"
        }
      ]
    },
    {
      "externalizable": true,
      "defaultValue": "false",
