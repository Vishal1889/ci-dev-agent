          "key": "all",
          "label": "All"
        },
        {
          "key": "specific",
          "label": "Specified Ones"
        }
      ]
    },
    {
      "externalizable": true,
      "dataType": "isTable",
      "key": "xmlJsonPathTable",
      "columns": [
        {
          "key": "xmlElement",
          "label": "XML Element"
        },
        {
          "key": "fromXsd",
          "label": ""
        }
