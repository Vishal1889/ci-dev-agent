# IDE
.vscode/

# OS files
Thumbs.db
Desktop.ini
.DS_Store

# Claude session data
.claude/

# Skill working/temp directories (legacy — pre-v2.5.0 path)
skills/*/.tmp/

# Skill working directory (v2.5.0+) — the skills now write here when this
# repo is itself the user's CWD (e.g. running dev installs against the local
# checkout via `npm install -g .`)
.ci-dev-agent/

# MCP server config (contains tenant-specific OAuth credentials — generated by `ci-dev-agent setup`)
config/mcp.json

# Tenant destination config (user-specific — generated by `ci-dev-agent configure tenants`)
config/tenant-destination-config.json

# Environment & secrets
.env
.env.*

# Playwright MCP
.playwright-mcp/

# Node
node_modules/
*.tgz
*.log
*.tmp
*.swp
*.swo
